## Backend (FastAPI) environment variables
#
# MongoDB Atlas connection string. Example:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://zuhoor_db_user:WCg11jUOLfLqvBvL@cluster0.1gf5hux.mongodb.net/?appName=Cluster0

# Database name inside your cluster
MONGODB_DB=performance_eval

# Set false to force JSON file storage in temp_storage/
USE_MONGO=true

# CORS origins (comma-separated). Prefer FRONTEND_ORIGINS.
# Example:
# FRONTEND_ORIGINS=http://localhost:3000,https://performance-evaluation-appinsnap.vercel.app
FRONTEND_ORIGINS=http://localhost:3000
# Backward compatible single-origin config:
FRONTEND_ORIGIN=http://localhost:3000

## Admin bootstrap
# Comma-separated list of emails to ensure exist as System Admin on backend startup.
# Example: ADMIN_EMAILS=admin@company.com,cto@company.com
ADMIN_EMAILS=

## SMTP (OTP email)
# Examples:
# - Gmail (recommended: App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
# - Office365:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

